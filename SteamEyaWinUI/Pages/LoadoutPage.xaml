<Page
    x:Class="SteamEyaWinUI.Pages.LoadoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SteamEyaWinUI.Models"
    xmlns:imaging="using:Microsoft.UI.Xaml.Media.Imaging"
    NavigationCacheMode="Required">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="LoadoutSectionBrush" Color="#78202020" />
                    <SolidColorBrush x:Key="LoadoutStrokeBrush" Color="#42FFFFFF" />
                    <SolidColorBrush x:Key="LoadoutWeaponCardBackgroundBrush" Color="#1A000000" />
                    <SolidColorBrush x:Key="LoadoutWeaponCardTextBrush" Color="#FFFFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="LoadoutSectionBrush" Color="#8AFFFFFF" />
                    <SolidColorBrush x:Key="LoadoutStrokeBrush" Color="#36FFFFFF" />
                    <SolidColorBrush x:Key="LoadoutWeaponCardBackgroundBrush" Color="#80000000" />
                    <SolidColorBrush x:Key="LoadoutWeaponCardTextBrush" Color="#FFFFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="LoadoutWeaponCardBorderBrush" Color="#4D000000" />
            <Style x:Key="LoadoutCellBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource LoadoutWeaponCardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource LoadoutWeaponCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
            <Style x:Key="LoadoutSectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="LoadoutEmptySlotStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="LoadoutWeaponNameStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource LoadoutWeaponCardTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- 可选武器（未装备）：图文比例约 45:55，可拖拽到上方格子。 -->
            <DataTemplate x:Key="PoolTileTemplate" x:DataType="models:LoadoutWeaponTile">
                <Border
                    Height="72"
                    Tag="{x:Bind}"
                    CornerRadius="8"
                    Background="{ThemeResource LoadoutWeaponCardBackgroundBrush}"
                    BorderBrush="{StaticResource LoadoutWeaponCardBorderBrush}"
                    BorderThickness="1"
                    PointerPressed="PoolItem_PointerPressed"
                    PointerMoved="DragSource_PointerMoved"
                    PointerReleased="DragSource_PointerReleased"
                    PointerCaptureLost="DragSource_PointerCaptureLost"
                    PointerCanceled="DragSource_PointerCanceled">
                    <Grid Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="9*" />
                            <ColumnDefinition Width="11*" />
                        </Grid.ColumnDefinitions>

                        <Image
                            Grid.Column="0"
                            Height="36"
                            MaxWidth="80"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Image.Source>
                                <imaging:SvgImageSource UriSource="{x:Bind IconUri}" />
                            </Image.Source>
                        </Image>

                        <Grid Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind DisplayName}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource LoadoutWeaponCardTextBrush}"
                                MaxLines="1"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="PageRoot" Background="Transparent">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <StackPanel Padding="24,20,24,24" Spacing="16">
                <Grid ColumnSpacing="16" Margin="4,0,4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind Strings.Get('Loadout_Title'), Mode=OneWay}"
                            Style="{StaticResource PageTitleTextStyle}"
                            VerticalAlignment="Center" />
                        <SelectorBar
                            x:Name="TeamSelector"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            SelectionChanged="TeamSelector_SelectionChanged">
                            <SelectorBarItem
                                x:Name="TeamTItem"
                                Text="{x:Bind Strings.Get('Loadout_Team_T'), Mode=OneWay}"
                                IsSelected="True" />
                            <SelectorBarItem
                                x:Name="TeamCtItem"
                                Text="{x:Bind Strings.Get('Loadout_Team_Ct'), Mode=OneWay}" />
                        </SelectorBar>
                </Grid>

                <StackPanel Spacing="14">
                        <Border CornerRadius="10" Padding="14" Background="{ThemeResource LoadoutSectionBrush}">
                            <Grid
                                x:Name="EquippedGrid"
                                ColumnSpacing="10"
                                HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid x:Name="Col0Host" Grid.Column="0" MinWidth="0" VerticalAlignment="Stretch" />
                                <Grid x:Name="Col1Host" Grid.Column="1" MinWidth="0" VerticalAlignment="Stretch" />
                                <Grid x:Name="Col2Host" Grid.Column="2" MinWidth="0" VerticalAlignment="Stretch" />
                            </Grid>
                        </Border>

                        <Border CornerRadius="10" Padding="12" Background="{ThemeResource LoadoutSectionBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="{x:Bind Strings.Get('Loadout_PoolHint'), Mode=OneWay}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                                <ItemsRepeater
                                    x:Name="PoolGrid"
                                    HorizontalAlignment="Stretch"
                                    ItemTemplate="{StaticResource PoolTileTemplate}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout
                                            Orientation="Horizontal"
                                            MaximumRowsOrColumns="3"
                                            MinColumnSpacing="10"
                                            MinRowSpacing="12"
                                            ItemsStretch="Fill" />
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 拖拽 ghost 图层：跟随指针的武器缩略，不参与命中检测。 -->
        <Canvas x:Name="DragLayer" IsHitTestVisible="False" />
    </Grid>
</Page>

<Page
    x:Class="SteamEyaWinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
        Padding="32,24,32,16">
        <StackPanel MaxWidth="820" Spacing="14" HorizontalAlignment="Left">
            <StackPanel Spacing="4">
                <TextBlock
                    Text="{x:Bind Strings.Get('Settings_Title'), Mode=OneWay}"
                    Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock
                    Text="{x:Bind Strings.Get('Settings_Subtitle'), Mode=OneWay}"
                    Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <!-- 语言：用 ComboBox 而非堆叠单选，既紧凑（避免页面出现多余滚动条）又适配可增长的语言列表 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock
                            Text="{x:Bind Strings.Get('Settings_Language_Section'), Mode=OneWay}"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            Text="{x:Bind Strings.Get('Settings_Language_Desc'), Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <!-- 语言自称名不随界面语言变化；选项在 code-behind 按已加载语言包动态生成 -->
                    <ComboBox
                        x:Name="LanguageComboBox"
                        Grid.Column="1"
                        MinWidth="180"
                        VerticalAlignment="Center"
                        SelectionChanged="LanguageComboBox_SelectionChanged" />
                </Grid>
            </Border>

            <!-- 主题 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock
                            Text="{x:Bind Strings.Get('Settings_Theme_Section'), Mode=OneWay}"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            Text="{x:Bind Strings.Get('Settings_Theme_Desc'), Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox
                        x:Name="ThemeComboBox"
                        Grid.Column="1"
                        MinWidth="180"
                        VerticalAlignment="Center"
                        SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Tag="Default" Content="{x:Bind Strings.Get('Settings_Theme_System'), Mode=OneWay}" />
                        <ComboBoxItem Tag="Light" Content="{x:Bind Strings.Get('Settings_Theme_Light'), Mode=OneWay}" />
                        <ComboBoxItem Tag="Dark" Content="{x:Bind Strings.Get('Settings_Theme_Dark'), Mode=OneWay}" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 全局字体：扫描运行目录 Assets/Fonts，支持打开目录并手动刷新。 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock
                            Text="{x:Bind Strings.Get('Settings_Font_Section'), Mode=OneWay}"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            Text="{x:Bind Strings.Get('Settings_Font_Desc'), Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ComboBox
                            x:Name="FontComboBox"
                            MinWidth="220"
                            MaxDropDownHeight="420"
                            IsTextSearchEnabled="True"
                            SelectionChanged="FontComboBox_SelectionChanged" />
                        <Button
                            x:Name="OpenFontFolderButton"
                            Width="36"
                            Height="32"
                            Padding="0"
                            Click="OpenFontFolderButton_Click"
                            AutomationProperties.Name="{x:Bind Strings.Get('Settings_Font_OpenFolder'), Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('Settings_Font_OpenFolder'), Mode=OneWay}">
                            <FontIcon Glyph="&#xE838;" FontSize="16" />
                        </Button>
                        <Button
                            x:Name="RefreshFontListButton"
                            Width="36"
                            Height="32"
                            Padding="0"
                            Click="RefreshFontListButton_Click"
                            AutomationProperties.Name="{x:Bind Strings.Get('Settings_Font_Refresh'), Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('Settings_Font_Refresh'), Mode=OneWay}">
                            <FontIcon Glyph="&#xE72C;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 毛玻璃与全局表面透明度。 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind Strings.Get('Settings_Glass_Section'), Mode=OneWay}"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                Text="{x:Bind Strings.Get('Settings_Glass_Desc'), Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="GlassEffectToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            OnContent="{x:Null}"
                            OffContent="{x:Null}"
                            VerticalAlignment="Center"
                            Toggled="GlassEffectToggle_Toggled" />
                    </Grid>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="{x:Bind Strings.Get('Settings_Glass_Opacity'), Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider
                            x:Name="BackgroundOpacitySlider"
                            Grid.Column="1"
                            Minimum="60"
                            Maximum="80"
                            StepFrequency="1"
                            ValueChanged="BackgroundOpacitySlider_ValueChanged" />
                        <TextBlock
                            x:Name="BackgroundOpacityText"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 更新站点：可选直连或代理站，手动检测当前选择站点延迟 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_UpdateProxy_Section'), Mode=OneWay}"
                        Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_UpdateProxy_Desc'), Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="UpdateProxyComboBox"
                            Grid.Column="0"
                            SelectionChanged="UpdateProxyComboBox_SelectionChanged">
                            <ComboBoxItem Tag="direct" Content="{x:Bind Strings.Get('Settings_UpdateProxy_Direct'), Mode=OneWay}" />
                            <ComboBoxItem Tag="gh-proxy.org" Content="{x:Bind Strings.Get('Settings_UpdateProxy_GhProxyOrg'), Mode=OneWay}" />
                            <ComboBoxItem Tag="v4.gh-proxy.org" Content="{x:Bind Strings.Get('Settings_UpdateProxy_GhProxyOrgV4'), Mode=OneWay}" />
                            <ComboBoxItem Tag="v6.gh-proxy.org" Content="{x:Bind Strings.Get('Settings_UpdateProxy_GhProxyOrgV6'), Mode=OneWay}" />
                            <ComboBoxItem Tag="cdn.gh-proxy.org" Content="{x:Bind Strings.Get('Settings_UpdateProxy_GhProxyOrgCdn'), Mode=OneWay}" />
                        </ComboBox>
                        <Button
                            x:Name="UpdateProxyLatencyButton"
                            Grid.Column="1"
                            Click="UpdateProxyLatencyButton_Click"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('Settings_UpdateProxy_LatencyButton'), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE895;" FontSize="14" />
                                <TextBlock Text="{x:Bind Strings.Get('Settings_UpdateProxy_LatencyButton'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Steam 安装路径：上号用的 Steam；装有多个 Steam 时可手动指定要用哪一个 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_SteamPath_Section'), Mode=OneWay}"
                        Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_SteamPath_Desc'), Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="SteamPathText"
                            VerticalAlignment="Center"
                            IsTextSelectionEnabled="True"
                            TextTrimming="CharacterEllipsis"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button
                            x:Name="ChangeSteamPathButton"
                            Grid.Column="1"
                            Click="ChangeSteamPathButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE838;" FontSize="16" />
                                <TextBlock Text="{x:Bind Strings.Get('Settings_Btn_ChangeSteamPath'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CS2 设置同步（issue #10）：登录时把来源账号的准星/灵敏度/键位等强推到目标账号的 Steam 云 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind Strings.Get('Settings_Cs2Sync_Section'), Mode=OneWay}"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                Text="{x:Bind Strings.Get('Settings_Cs2Sync_Desc'), Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="Cs2SyncToggle"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            MinWidth="0"
                            OnContent="{x:Null}"
                            OffContent="{x:Null}"
                            Toggled="Cs2SyncToggle_Toggled" />
                    </Grid>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind Strings.Get('Settings_Cs2Sync_Source'), Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <AutoSuggestBox
                            x:Name="Cs2SyncSourceBox"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            QueryIcon="Find"
                            UpdateTextOnSelect="False"
                            PlaceholderText="{x:Bind Strings.Get('Settings_Cs2Sync_Source_Placeholder'), Mode=OneWay}"
                            TextChanged="Cs2SyncSourceBox_TextChanged"
                            QuerySubmitted="Cs2SyncSourceBox_QuerySubmitted"
                            GotFocus="Cs2SyncSourceBox_GotFocus"
                            LostFocus="Cs2SyncSourceBox_LostFocus" />
                        <Button
                            x:Name="Cs2SyncRefreshButton"
                            Grid.Column="2"
                            Click="Cs2SyncRefreshButton_Click"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('Common_Refresh'), Mode=OneWay}">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                        <Button
                            x:Name="Cs2SyncPushNowButton"
                            Grid.Column="3"
                            Click="Cs2SyncPushNowButton_Click"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('Settings_Cs2Sync_PushNow_Tooltip'), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE898;" FontSize="14" />
                                <TextBlock Text="{x:Bind Strings.Get('Settings_Cs2Sync_PushNow'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_Cs2Sync_Note'), Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 数据 -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_Data_Section'), Mode=OneWay}"
                        Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock
                        Text="{x:Bind Strings.Get('Settings_Data_Desc'), Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="DataFolderPathText"
                            VerticalAlignment="Center"
                            IsTextSelectionEnabled="True"
                            TextTrimming="CharacterEllipsis"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button
                            x:Name="OpenDataFolderButton"
                            Grid.Column="1"
                            Click="OpenDataFolderButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE838;" FontSize="16" />
                                <TextBlock Text="{x:Bind Strings.Get('Settings_Btn_OpenDataFolder'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
